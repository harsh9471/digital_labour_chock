# ============================================================
# DIGITAL LABOUR CHOWK - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://dlc_user:dlc_password@localhost:5432/digital_labour_chowk?schema=public"
POSTGRES_USER=dlc_user
POSTGRES_PASSWORD=dlc_password
POSTGRES_DB=digital_labour_chowk
POSTGRES_PORT=5432

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dlc_redis_password
REDIS_URL="redis://:dlc_redis_password@localhost:6379"

# ============================================================
# JWT CONFIGURATION
# ============================================================
JWT_ACCESS_SECRET=your-super-secret-jwt-access-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# API CONFIGURATION
# ============================================================
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=api/v1
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Digital Labour Chowk"

# ============================================================
# OTP CONFIGURATION
# ============================================================
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# ============================================================
# SMS PROVIDER (Twilio / MSG91)
# ============================================================
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=DLCHOW
MSG91_TEMPLATE_ID=your-template-id

# TWILIO (alternative)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# EMAIL CONFIGURATION (SendGrid / SMTP)
# ============================================================
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM_NAME="Digital Labour Chowk"
MAIL_FROM_EMAIL=noreply@digitallabourchowk.com

# SENDGRID (alternative)
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================================
# FILE STORAGE
# ============================================================
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 (production)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=digital-labour-chowk-uploads

# ============================================================
# RATE LIMITING
# ============================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
LOG_FORMAT=json
